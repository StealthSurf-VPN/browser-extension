{
	"manifest_version": 3,
	"name": "StealthSurf VPN",
	"short_name": "StealthSurf",
	"version": "1.0.4",
	"description": "Браузерное расширение для пользователей сервиса. Подключайтесь к своим конфигам прямо из браузера — без лишних настроек.",
	"author": "StealthSurf VPN",
	"homepage_url": "https://stealthsurf.app",
	"minimum_chrome_version": "88",
	"permissions": [
		"identity",
		"proxy",
		"storage",
		"webRequest",
		"webRequestAuthProvider",
		"alarms",
		"management"
	],
	"host_permissions": ["<all_urls>"],
	"action": {
		"default_popup": "src/assets/popup.html",
		"default_icon": {
			"16": "icons/icon-16.png",
			"32": "icons/icon-32.png",
			"48": "icons/icon-48.png",
			"128": "icons/icon-128.png"
		}
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"icons": {
		"16": "icons/icon-16.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	},
	"web_accessible_resources": [
		{
			"resources": ["callback.html"],
			"matches": ["https://console.stealthsurf.app/*"]
		}
	],
	"offline_enabled": true
}
