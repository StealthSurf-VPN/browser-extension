{
	"manifest_version": 2,
	"name": "StealthSurf VPN",
	"short_name": "StealthSurf",
	"version": "1.0.4",
	"description": "Браузерное расширение для пользователей сервиса. Подключайтесь к своим конфигам прямо из браузера — без лишних настроек.",
	"author": "StealthSurf VPN",
	"homepage_url": "https://stealthsurf.app",
	"developer": {
		"name": "StealthSurf VPN",
		"url": "https://stealthsurf.app"
	},
	"permissions": [
		"proxy",
		"storage",
		"webRequest",
		"webRequestBlocking",
		"<all_urls>",
		"alarms",
		"management"
	],
	"browser_action": {
		"default_popup": "src/assets/popup.html",
		"default_icon": {
			"16": "icons/icon-16.png",
			"32": "icons/icon-32.png",
			"48": "icons/icon-48.png",
			"128": "icons/icon-128.png"
		}
	},
	"background": {
		"scripts": ["background.js"],
		"type": "module",
		"persistent": true
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "admin@stealthsurf.app",
			"strict_min_version": "91.0",
			"update_url": "https://raw.githubusercontent.com/stealthsurf-vpn/browser-extension/main/updates.json"
		}
	},
	"icons": {
		"16": "icons/icon-16.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	},
	"web_accessible_resources": ["callback.html"]
}
