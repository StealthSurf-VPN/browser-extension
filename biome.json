{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			".git/**",
			"node_modules/**",
			"yarn.lock",
			"package-lock.json",
			".yarn/**",
			"dist",
			"public"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"security": {
				"noDangerouslySetInnerHtml": "error"
			},
			"suspicious": {
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"useButtonType": "off",
				"useKeyWithClickEvents": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "off",
				"noUnusedImports": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		},
		"jsxRuntime": "reactClassic"
	},
	"overrides": [
		{
			"include": ["src/shared/pacIpHelpers.js"],
			"linter": {
				"rules": {
					"style": {
						"useTemplate": "off",
						"noVar": "off",
						"useNumberNamespace": "off"
					},
					"correctness": {
						"noInnerDeclarations": "off"
					}
				}
			}
		}
	]
}
